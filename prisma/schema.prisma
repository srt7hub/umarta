generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  FIRST_COURSE   // Первые блюда
  SIDE_DISH      // Гарниры
  FISH           // Рыбные блюда
  MEAT           // Мясные блюда
  COLD_APPETIZER // Холодные закуски
  APPETIZER      // Закуски
  SALAD          // Салаты
  DRINK          // Напитки
  SERVICE        // Дополнительные услуги
}

enum EventStatus {
  DRAFT
  CONFIRMED
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Dish {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    Category
  // Цена за одного гостя, в копейках/центах для избежания ошибок с плавающей точкой
  pricePerGuest Int
  imageUrl    String?
  active      Boolean  @default(true)
  // Обязательная позиция (например, обслуживание): всегда включена,
  // клиент не может её снять.
  mandatory   Boolean  @default(false)
  // Фиксированная стоимость за всё мероприятие (а не за гостя).
  // Используется для услуг с фиксом за зал: цена НЕ умножается на гостей.
  perEvent    Boolean  @default(false)
  // Информационная позиция (например, оформление зала): клиент может
  // отметить «нужно / не нужно», но цена в итоговую стоимость НЕ входит.
  // pricePerGuest здесь — справочная «от …».
  informational Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventDishes EventDish[]
}

model Event {
  id        String      @id @default(cuid())
  token     String      @unique @default(cuid())
  title     String
  clientName String
  eventDate DateTime
  guests    Int
  status    EventStatus @default(DRAFT)
  // Сумма внесённого задатка за банкет, в копейках. Вычитается из итога
  // в смете («Осталось доплатить»). 0 — задаток не внесён.
  depositAmount Int     @default(0)
  // Отметка администратора «задаток оплачен» (галочка в списке мероприятий).
  depositPaid Boolean   @default(false)
  // Снимок на момент подтверждения: дата и число гостей фиксируются,
  // чтобы итог подтверждённого меню не «поехал» при правках каталога/гостей.
  confirmedAt     DateTime?
  guestsAtConfirm Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  dishes    EventDish[]
  items     EventItem[]
}

// Произвольная позиция сметы конкретного мероприятия (доп. услуга, аренда,
// скидка и т.п.), добавляется менеджером вручную. В каталоге блюд не хранится.
model EventItem {
  id        String   @id @default(cuid())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String
  name      String
  // Сумма в копейках. perGuest=true → за одного гостя (× число гостей),
  // perGuest=false → фиксированная за всё мероприятие.
  amount    Int
  perGuest  Boolean  @default(false)
  // Снимок суммы на момент подтверждения (null пока DRAFT).
  amountAtConfirm Int?
  createdAt DateTime @default(now())
}

// Связь выбранных клиентом блюд с мероприятием
model EventDish {
  id      String @id @default(cuid())
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  dish    Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)
  dishId  String
  // Снимок на момент подтверждения. null пока меню в DRAFT (цена живая из
  // каталога). После подтверждения итог считается из этих полей, поэтому
  // правки цен в каталоге не затрагивают подтверждённые мероприятия.
  priceAtConfirm Int?
  perEventAtConfirm     Boolean?
  informationalAtConfirm Boolean?

  @@unique([eventId, dishId])
}
