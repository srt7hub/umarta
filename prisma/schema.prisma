generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  FIRST_COURSE   // Первые блюда
  SIDE_DISH      // Гарниры
  FISH           // Рыбные блюда
  MEAT           // Мясные блюда
  COLD_APPETIZER // Холодные закуски
  APPETIZER      // Закуски
  SALAD          // Салаты
  DRINK          // Напитки
  SERVICE        // Дополнительные услуги
}

enum EventStatus {
  DRAFT
  CONFIRMED
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Dish {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    Category
  // Цена за одного гостя, в копейках/центах для избежания ошибок с плавающей точкой
  pricePerGuest Int
  imageUrl    String?
  active      Boolean  @default(true)
  // Обязательная позиция (например, обслуживание): всегда включена,
  // клиент не может её снять.
  mandatory   Boolean  @default(false)
  // Фиксированная стоимость за всё мероприятие (а не за гостя).
  // Используется для услуг с фиксом за зал: цена НЕ умножается на гостей.
  perEvent    Boolean  @default(false)
  // Информационная позиция (например, оформление зала): клиент может
  // отметить «нужно / не нужно», но цена в итоговую стоимость НЕ входит.
  // pricePerGuest здесь — справочная «от …».
  informational Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventDishes EventDish[]
}

model Event {
  id        String      @id @default(cuid())
  token     String      @unique @default(cuid())
  title     String
  clientName String
  eventDate DateTime
  guests    Int
  status    EventStatus @default(DRAFT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  dishes    EventDish[]
}

// Связь выбранных клиентом блюд с мероприятием
model EventDish {
  id      String @id @default(cuid())
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  dish    Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)
  dishId  String

  @@unique([eventId, dishId])
}
