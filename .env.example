# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/banquet?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Публичный адрес сайта для ссылок клиентам (с доменом/IP, как клиент
# открывает сайт). Подставляется в ссылку на меню. Пример для прод-сервера:
# NEXT_PUBLIC_APP_URL="http://199.189.254.104:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Initial admin credentials (used by the seed script)
ADMIN_EMAIL="admin@banquet.local"
ADMIN_PASSWORD="admin123"
